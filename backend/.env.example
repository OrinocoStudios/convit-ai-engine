# Server
PORT=3000

# Orígenes CORS permitidos (coma-separado). Vacío o * = permitir cualquier origen (solo dev/red cerrada).
# Ejemplo dev (convit-ai-client con Vite): CORS_ORIGINS=http://localhost:5173
# Ejemplo producción: CORS_ORIGINS=https://convit.hospital.local
CORS_ORIGINS=

# MongoDB
MONGO_URI=mongodb://localhost:27017/convit

# Brain Service (RAG / grafo y embeddings viven en este servicio externo)
BRAIN_SERVICE_URL=http://localhost:8081
BRAIN_SERVICE_API_KEY=

# Storage local de documentos clínicos
STORAGE_BASE_PATH=./storage
